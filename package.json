{
  "name": "termlearn",
  "version": "0.1.0",
  "private": true,
  "description": "任意课程考纲驱动的终端拟态 AI 学习桌面应用",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "tsc --noEmit && vite build && tsc -p electron/tsconfig.json",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit && tsc -p electron/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^38.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.0.0",
    "playwright": "^1.61.1",
    "typescript": "^5.8.0",
    "wait-on": "^8.0.0"
  }
}
